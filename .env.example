# ─── App ────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000/"
NEXTAUTH_SECRET="YOUR_SECRET"

# ─── Database ────────────────────────────────────────────────────────────────
MONGO_URI="mongodb://localhost:27017/open-hr"

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET="YOUR_JWT_SECRET"
JWT_TOKEN_EXPIRE="7d"
SALT_ROUND=10
ID_GENERATOR_PREFIX="EMP"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Email (nodemailer) ───────────────────────────────────────────────────────
SENDER_EMAIL=""
EMAIL_PASSWORD=""

# ─── DigitalOcean Spaces (S3-compatible) ─────────────────────────────────────
NEXT_PUBLIC_BUCKET_URL="https://BUCKET_NAME.fra1.cdn.digitaloceanspaces.com"
DOS_PUBLIC_ACCESS_KEY=""
DOS_PUBLIC_SECRET_KEY=""
DOS_BUCKET_NAME=""
DOS_REGION="fra1"

# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=""
